# Silicon Radar — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Gemini API ──────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey (free, no credit card)
# GEMINI_API_KEY is the fallback if GEMINI_API_KEYS is not set
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list for key rotation (recommended: 3-6 independent projects)
# Gemini quota is project-scoped: extra keys from one project share its limit.
GEMINI_API_KEYS=key1,key2,key3,key4,key5,key6

# Keep v1 until the optional deep_dive JSONB migration has been applied.
# INTELLIGENCE_PROMPT_VERSION=v2

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase project → Settings → API
# Create a free project at https://supabase.com (500MB free)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-region.pooler.supabase.com:6543/postgres

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow prompts → get token
TELEGRAM_TOKEN=your_bot_token_here

# 2. Get your chat ID:
#    - Message @userinfobot on Telegram
#    - Or start your bot and visit:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Twitter/X ────────────────────────────────────────────────────────────────
# Cookie-based auth (bypasses Cloudflare on VPS/datacenter IPs)
# Get from browser DevTools → Application → Cookies → x.com
TWITTER_USERNAME=your_twitter_username
TWITTER_COOKIES=auth_token=your_auth_token; ct0=your_ct0_token
