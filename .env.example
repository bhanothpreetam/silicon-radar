# Silicon Radar — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git


# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase project → Settings → API
# Create a free project at https://supabase.com (500MB free)
SUPABASE_URL=
SUPABASE_KEY=
# Connection string for psycopg2 (Supabase → Settings → Database → Connection string)
# Use the "URI" format
DATABASE_URL=
# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow prompts → get token
TELEGRAM_TOKEN=
# 2. Get your chat ID:
#    - Message @userinfobot on Telegram
#    - Or start your bot and visit:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
